<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Yohannes's Portfolio</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap" rel="stylesheet">
    <style>
        html {
            scroll-behavior: smooth;
        }

        body {
            font-family: 'Inter', Arial, sans-serif;
            line-height: 1.6;
            color: #333;
            background-color: #f9f9f9;
            margin: 0;
            padding: 20px;
        }

        .container {
            max-width: 800px;
            margin: 0 auto;
            background: #ffffff;
            padding: 30px;
            border-radius: 8px;
            box-shadow: 0 2px 5px rgba(0,0,0,0.1);
        }

        nav {
            display: flex;
            justify-content: space-between;
            align-items: center;
            border-bottom: 2px solid #eeeeee;
            padding-bottom: 10px;
            margin-bottom: 30px;
        }

        nav ul {
            list-style: none;
            display: flex;
            gap: 15px;
            margin: 0;
            padding: 0;
        }

        nav a {
            text-decoration: none;
            color: #0066cc;
            font-weight: 600;
            transition: color 0.3s;
        }

        nav a:hover {
            color: #004c99;
        }

        .profile-img {
            width: 150px;
            height: 150px;
            border-radius: 50%;
            object-fit: cover;
        }

        @keyframes slideInUp {
            from {
                opacity: 0;
                transform: translateY(40px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .section {
            margin-bottom: 40px;
            padding-top: 20px;
            opacity: 0;
            animation: slideInUp 0.8s ease-out forwards;
        }

        .section:nth-child(1) { animation-delay: 0.1s; }
        .section:nth-child(2) { animation-delay: 0.3s; }
        .section:nth-child(3) { animation-delay: 0.5s; }
        .section:nth-child(4) { animation-delay: 0.7s; }

        .btn-group {
            margin-top: 15px;
            display: flex;
            gap: 10px;
            flex-wrap: wrap;
        }

        .scroll-btn {
            display: inline-block;
            background-color: #0066cc;
            color: #ffffff;
            padding: 12px 25px;
            text-decoration: none;
            border-radius: 30px;
            font-weight: 600;
            transition: background-color 0.3s ease, transform 0.2s ease;
            box-shadow: 0 4px 6px rgba(0,0,0,0.1);
        }

        .scroll-btn:hover {
            background-color: #004c99;
            transform: translateY(-3px);
            color: #ffffff;
        }

        .outline-btn {
            display: inline-block;
            background-color: transparent;
            color: #0066cc;
            border: 2px solid #0066cc;
            padding: 10px 20px;
            text-decoration: none;
            border-radius: 30px;
            font-weight: 600;
            transition: all 0.3s ease;
        }

        .outline-btn:hover {
            background-color: #0066cc;
            color: #ffffff;
        }

        .projects-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
            gap: 20px;
            margin-top: 20px;
        }

        .project-card {
            border: 1px solid #eaeaea;
            padding: 20px;
            border-radius: 8px;
            background-color: #fafafa;
            transition: transform 0.3s ease, box-shadow 0.3s ease;
        }

        .project-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 6px 12px rgba(0,0,0,0.1);
        }

        .project-card h3 {
            margin-top: 0;
            color: #0066cc;
        }

        .tags {
            margin: 10px 0;
            display: flex;
            gap: 5px;
            flex-wrap: wrap;
        }

        .tag {
            background-color: #e0e0e0;
            padding: 4px 8px;
            border-radius: 4px;
            font-size: 0.8rem;
            font-weight: 600;
        }

        form {
            max-width: 100%;
        }
        
        input[type="text"],
        input[type="email"],
        textarea {
            width: 100%;
            padding: 10px;
            margin-top: 5px;
            margin-bottom: 15px;
            border: 1px solid #ccc;
            border-radius: 4px;
            box-sizing: border-box;
            font-family: inherit;
        }

        button[type="submit"] {
            background-color: #0066cc;
            color: white;
            padding: 10px 25px;
            border: none;
            border-radius: 5px;
            font-weight: bold;
            cursor: pointer;
            transition: background-color 0.3s;
        }

        button[type="submit"]:hover {
            background-color: #004c99;
        }

        footer {
            text-align: center;
            padding-top: 20px;
            margin-top: 40px;
            border-top: 1px solid #eeeeee;
            font-size: 0.9rem;
            color: #777777;
        }

        #roleTitle {
            cursor: pointer;
            transition: color 0.3s ease;
        }
    </style>
</head>
<body>

    <div class="container">

        <header>
            <nav>
                <a href="#home">
                    <strong>Yohannes's Portfolio</strong>
                </a>
                <ul>
                    <li><a href="#home">Home</a></li>
                    <li><a href="#about">About Me</a></li>
                    <li><a href="#projects">Projects</a></li>
                    <li><a href="#contact">Contact</a></li>
                </ul>
            </nav>
        </header>

        <main>
            <section id="home" class="section">
                <h1>Yohannes Kumlachew</h1>
                <img class="profile-img" src="Profile picture.png" alt="Yohannes Kumlachew" />
                
                <p>
                    <b id="roleTitle" onclick="changeTitle()">Information Technology and Systems Student</b>
                </p>
                
                <div class="btn-group">
                    <a href="#about" class="scroll-btn">Scroll Down ↓</a>
                    <a href="https://github.com/yoaibo" class="outline-btn" target="_blank">GitHub</a>
                </div>
            </section>

            <section id="about" class="section">
                <h2>About Me</h2>
                
                <p>
                    I'm an Information Technology and Systems student and passionate developer with experience in 
                    building responsive and user-friendly applications. I enjoy turning ideas into 
                    functional projects and continuously improving my skills in both frontend and 
                    backend development.
                </p>

                <p>
                    I'm skilled in HTML, CSS, Python, and Java, and I'm always eager to learn new 
                    technologies and frameworks to expand my capabilities. Alongside programming, 
                    I also have experience in graphic design, which helps me create clean and 
                    visually appealing user experiences.
                </p>

                <h3>Skills</h3>
                <ul>
                    <li>HTML</li>
                    <li>CSS</li>
                    <li>Python</li>
                    <li>Java</li>
                    <li>Responsive Web Design</li>
                    <li>Problem Solving</li>
                    <li>Graphic Design</li>
                </ul>

                <h3>Frameworks & Tools</h3>
                <ul>
                    <li>Java Swing</li>
                    <li>Git & GitHub</li>
                    <li>VS Code</li>
                    <li>IntelliJ IDEA</li>
                </ul>
            </section>

            <section id="projects" class="section">
                <h2>Projects</h2>
                <div class="projects-grid">
                    <div class="project-card">
                        <h3>Vehicle Management System</h3>
                        <p>A comprehensive system designed to track and manage vehicle fleets, monitor maintenance schedules, and handle operational logistics efficiently.</p>
                        <div class="tags">
                            <span class="tag">Java</span>
                            <span class="tag">Java Swing</span>
                        </div>
                    </div>

                    <div class="project-card">
                        <h3>Zoo Management System</h3>
                        <p>An interactive application built to streamline daily zoo operations, including animal health tracking, enclosure assignments, and staff scheduling.</p>
                        <div class="tags">
                            <span class="tag">Python</span>
                            <span class="tag">Database Design</span>
                        </div>
                    </div>

                    <div class="project-card">
                        <h3>Property & Damage Reporting</h3>
                        <p>A specialized platform for property managers and tenants to log, track, and resolve property damage reports in real-time.</p>
                        <div class="tags">
                            <span class="tag">HTML/CSS</span>
                            <span class="tag">Backend Logic</span>
                        </div>
                    </div>
                </div>
            </section>

            <section id="contact" class="section">
                <h2>Contact</h2>
                <p>Email: yohannes.kumlachew@bitscollege.edu.et</p>
                <p>Phone: +251987654321</p>
                
                <h3>Send Me A Message</h3>

                <form action="https://formspree.io/f/YOUR_FORM_ID_HERE" method="POST">
                    <label for="name">Name:</label><br>
                    <input type="text" id="name" name="name" placeholder="Enter your name" required>

                    <label for="email">Email:</label><br>
                    <input type="email" id="email" name="email" placeholder="Enter your email" required>

                    <label for="message">Message:</label><br>
                    <textarea id="message" name="message" rows="5" placeholder="Write your message here..." required></textarea>

                    <button type="submit" id="submitBtn" onclick="sendMessage(event)">Send</button>
                </form>
            </section>
        </main>
        
        <footer>
            &copy; 2026 Yohannes Kumlachew. Built with HTML & CSS.
        </footer>

    </div>

    <script>
        function sendMessage(event) {
            let nameInput = document.getElementById("name").value;
            let emailInput = document.getElementById("email").value;
            let messageInput = document.getElementById("message").value;

            if(nameInput !== "" && emailInput !== "" && messageInput !== "") {
                event.preventDefault();
                let btn = document.getElementById("submitBtn");
                btn.textContent = "Message Sent!";
                btn.style.backgroundColor = "#28a745";
                alert("Thank you " + nameInput + ", your message has been received.");
            }
        }

        function changeTitle() {
            let role = document.getElementById("roleTitle");
            if(role.style.color === "rgb(0, 102, 204)") {
                role.textContent = "Information Technology and Systems Student";
                role.style.color = "#333";
            } else {
                role.textContent = "Passionate Developer & IT Student";
                role.style.color = "#0066cc";
            }
        }
    </script>
</body>
</html>
